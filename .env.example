# Application
NODE_ENV=development
PORT=3000
APP_PORT=3000
APP_HOST=127.0.0.1
JWT_SECRET=replace-with-a-long-random-secret-of-at-least-32-characters
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=leitner_session
AUTH_COOKIE_MAX_AGE_MS=604800000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
TRUST_PROXY=false

# MySQL application connection (least privilege)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=leitner_ielts
DB_USER=leitner_app
DB_PASSWORD=replace-with-a-strong-app-password
DB_CONNECT_RETRIES=30
DB_CONNECT_RETRY_MS=2000
DB_CONNECTION_LIMIT=10

# Database setup connection (schema administration only).
# With Docker Compose this password must match MYSQL_ROOT_PASSWORD below.
DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=replace-with-a-strong-root-password

# MySQL container bootstrap
MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password

# Both app and phpMyAdmin are bound to localhost by default in docker-compose.yml.
# Set APP_HOST=0.0.0.0 only when a firewall/reverse proxy protects the server.
PHPMYADMIN_PORT=8081
