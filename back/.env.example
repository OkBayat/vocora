NODE_ENV=development
PORT=3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=leitner_ielts
DB_USER=leitner_app
DB_PASSWORD=replace-with-a-strong-app-password
DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=change-this-root-password
DB_CONNECTION_LIMIT=10
DB_CONNECT_RETRIES=30
DB_CONNECT_RETRY_MS=2000

# Use a long, random value in production (at least 32 characters).
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=leitner_session
AUTH_COOKIE_MAX_AGE_MS=604800000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
TRUST_PROXY=false
